using './main.bicep'

param location = 'japaneast'
param functionAppName = '<function-app-name>'
param storageAccountName = '<storage-account-name>'
param functionPlanName = '<function-plan-name>'
param logAnalyticsWorkspaceName = '<log-analytics-workspace-name>'
param applicationInsightsName = '<application-insights-name>'
param webPubSubName = '<web-pubsub-name>'
param webPubSubSkuName = 'Free_F1'
param webPubSubUnitCount = 1
param webPubSubHubName = 'livecaption'
param webPubSubGroupName = 'caption-live'
param viewerAccessCodeRequired = true
param azureOpenAIName = '<azure-openai-name>'
param azureOpenAILocation = 'southindia'
param azureOpenAICustomSubdomainName = '<azure-openai-custom-subdomain>'
param azureOpenAIDisableLocalAuth = false
param azureOpenAITranslationDeploymentName = 'realtime-translate'
param azureOpenAITranslationModelName = 'gpt-realtime-translate'
param azureOpenAITranslationModelVersion = '2026-05-06'
param azureOpenAITranscriptionDeploymentName = 'realtime-whisper'
param azureOpenAITranscriptionModelName = 'gpt-realtime-whisper'
param azureOpenAITranscriptionModelVersion = '2026-05-06'
param azureOpenAITranslationDeploymentSkuName = 'GlobalStandard'
param azureOpenAITranslationDeploymentCapacity = 1
param azureOpenAITranscriptionDeploymentSkuName = 'GlobalStandard'
param azureOpenAITranscriptionDeploymentCapacity = 1
param speechResourceGroupName = 'iplayground'
param speechAccountName = '<speech-account-name>'
param githubRepository = 'iplayground/LiveCaption'
param githubBranch = 'main'
